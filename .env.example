# Office Agents - Docker Configuration
# Copy to .env and adjust as needed

# LLM model (must be available in Ollama)
LLM_MODEL=qwen3.5:35b

# Tavily API key for web search (optional, falls back to DuckDuckGo)
TAVILY_API_KEY=

# Simulation tick interval in seconds (lower = faster but more GPU load)
TICK_INTERVAL=4.0

# Port to expose the frontend on
PORT=4454

# Host directory to mount as readable files for agents
HOST_FILES_PATH=/home/nvidia/documents
